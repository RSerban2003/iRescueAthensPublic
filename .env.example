# ──────────────────────────────────────────────────────────────────────────────
# iRescue Athens — environment configuration
# Copy this file to .env and fill in the values. Only DATABASE_URL,
# NEXTAUTH_URL and NEXTAUTH_SECRET are required to run the app locally.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# The default below matches the bundled docker-compose.yml (`npm run db:up`).
DATABASE_URL="postgresql://irescue:irescue@localhost:5432/irescue"

# Base URL of the app (used by NextAuth and in emails/Stripe redirects).
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret for signing NextAuth session tokens.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-random-secret"

# ── Email notifications (optional) ───────────────────────────────────────────
# When EMAIL_USER / EMAIL_PASSWORD are unset, notification emails are logged to
# the server console instead of being sent — the app works fine without them.
# For Gmail use an App Password (https://myaccount.google.com/apppasswords);
# regular passwords no longer work.
# EMAIL_USER="you@example.com"
# EMAIL_PASSWORD="your-smtp-app-password"
# EMAIL_HOST="smtp.gmail.com"          # default: smtp.gmail.com
# EMAIL_PORT="587"                     # default: 587
# EMAIL_SECURE="false"                 # "true" for port 465
# EMAIL_RECEIVER="owner@example.com"   # where notifications go; default: EMAIL_USER

# ── Stripe (optional, test mode) ─────────────────────────────────────────────
# When STRIPE_SECRET_KEY is unset, the "pay online" option is hidden and
# purchases fall back to pay-in-store — nothing crashes.
# Get test keys at https://dashboard.stripe.com/test/apikeys
# STRIPE_SECRET_KEY="sk_test_..."

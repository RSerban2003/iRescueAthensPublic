{
  "name": "irescue-athens",
  "version": "1.0.0",
  "private": true,
  "description": "Phone repair & refurbished-device storefront for iRescue Athens: repair booking, buy/sell flows, and an admin dashboard.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "setup": "npm install && prisma migrate deploy && prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^15.5.19",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "react": "^19.2.7",
    "react-calendar": "^5.1.0",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "stripe": "^22.2.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.13.2",
    "@types/nodemailer": "^7.0.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum BookingType {
  REPAIR
  PURCHASE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  ONLINE
  IN_STORE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

enum PhoneStatus {
  AVAILABLE
  SOLD
  HIDDEN
}

enum Condition {
  LIKE_NEW
  EXCELLENT
  GOOD
  FAIR
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A customer appointment: either a repair drop-off or a purchase pickup.
model Booking {
  id              String         @id @default(cuid())
  type            BookingType
  status          BookingStatus  @default(PENDING)
  date            DateTime       @db.Date
  timeSlot        String
  name            String
  email           String
  phone           String
  notes           String?
  // Repair details
  brand           String?
  model           String?
  issues          String[]       @default([])
  // Payment
  totalAmount     Float?
  paymentMethod   PaymentMethod?
  paymentStatus   PaymentStatus?
  stripeSessionId String?
  // Purchase target
  phoneForSale    PhoneForSale?  @relation(fields: [phoneForSaleId], references: [id], onDelete: SetNull)
  phoneForSaleId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([date])
  @@index([status])
}

/// A device a customer wants to sell to the shop.
model PhoneListing {
  id          String        @id @default(cuid())
  brand       String
  model       String
  storage     String
  condition   Condition
  description String?
  askingPrice Float
  images      String[]      @default([])
  status      ListingStatus @default(PENDING)
  // Seller contact
  name        String
  email       String
  phone       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

/// Refurbished inventory offered in the shop.
model PhoneForSale {
  id          String      @id @default(cuid())
  brand       String
  model       String
  price       Float
  condition   Condition
  storage     String
  color       String
  year        Int?
  description String?
  images      String[]    @default([])
  status      PhoneStatus @default(AVAILABLE)
  bookings    Booking[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
}

/// A calendar day on which the shop accepts appointments.
model AvailableDay {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  note      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton-ish config row holding the bookable time slots.
model AvailabilityConfig {
  id        String   @id @default(cuid())
  slots     String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
